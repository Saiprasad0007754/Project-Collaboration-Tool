# Base URL of the backend API (Vite exposes only VITE_ prefixed vars to the client)
VITE_API_BASE_URL=http://localhost:5000/api/v1

# Base URL for the Socket.IO connection (usually same host as backend, without the API path)
VITE_SOCKET_URL=http://localhost:5000

# App metadata
VITE_APP_NAME=Project Collab Tool
