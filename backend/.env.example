# ===========================
# SERVER CONFIGURATION
# ===========================
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
API_PREFIX=/api/v1

# ===========================
# MONGODB CONFIGURATION
# ===========================
MONGO_URI=mongodb://127.0.0.1:27017/project_collab_tool
MONGO_URI_TEST=mongodb://127.0.0.1:27017/project_collab_tool_test

